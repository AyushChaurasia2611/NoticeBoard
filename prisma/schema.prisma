datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Priority {
  Urgent
  Normal
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    String   // 'Exam', 'Event', 'General'
  priority    Priority
  publishDate DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
